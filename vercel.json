{
  "version": 2,
  "functions": {
    "api/chat.js":      { "maxDuration": 10 },
    "api/vision.js":    { "maxDuration": 10 },
    "api/imagine.js":   { "maxDuration": 10 },
    "api/search.js":    { "maxDuration": 10 },
    "api/rag.js":       { "maxDuration": 10 },
    "api/memory.js":    { "maxDuration": 10 },
    "api/github.js":    { "maxDuration": 10 },
    "api/intel.js":     { "maxDuration": 10 },
    "api/imageedit.js": { "maxDuration": 10 },
    "api/mediapipe.js": { "maxDuration": 10 },
    "api/tts.js":       { "maxDuration": 10 },
    "api/utils.js":     { "maxDuration": 5  }
  },
  "headers": [
    {
      "source": "/mediapipe/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    }
  ]
