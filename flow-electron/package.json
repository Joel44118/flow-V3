{
  "name": "flow-ai",
  "version": "1.2.11",
  "description": "Flow AI Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.joelflowstack.flow",
    "productName": "Flow AI",
    "files": [
      "main.js",
      "preload.js",
      "wakeword-engine.js",
      "heartbeat.js",
      "memory-store.js",
      "icon.png",
      "build-info.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "resources/wakeword", "to": "wakeword" },
      { "from": "resources/sox",      "to": "sox" }
    ],
    "publish": {
      "provider": "github",
      "owner": "Joel44118",
      "repo": "flow-V3"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Flow AI"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.8",
    "@jitsi/robotjs": "^0.6.12",
    "active-win": "^9.0.0",
    "onnxruntime-node": "^1.19.0",
    "vectra": "^0.15.0"
  }
}
