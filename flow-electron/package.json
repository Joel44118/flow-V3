{
  "name": "flow-ai-desktop",
  "version": "1.0.0",
  "description": "Flow AI Desktop App",
  "main": "main.js",
  "scripts": {
    "start":     "electron .",
    "build-win": "electron-builder --win --x64"
  },
  "build": {
    "appId":       "com.joelflowstack.flow",
    "productName": "Flow AI",
    "files":       ["main.js", "preload.js", "icon.png"],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon":   "icon.png"
    }
  },
  "devDependencies": {
    "electron":         "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@jitsi/robotjs": "^0.6.12"
  }
}
